APP_NAME=AuthMocker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=authmocker
DB_USERNAME=authmocker
DB_PASSWORD=secret

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

AUTH_TOKEN_TTL=3600
AUTH_REFRESH_TTL=604800
